{
  "name": "IngenuityAI",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "dotenv -- turbo run dev",
    "infra:up": "dotenv -- docker compose -f infra/dev.compose.yaml up -d",
    "infra:down": "dotenv -- docker compose -f infra/dev.compose.yaml down",
    "db:migrate": "dotenv -- pnpm --filter @ingenuityai/backend run db:migrate",
    "db:generate": "dotenv -- turbo run db:generate",
    "db:studio": "dotenv -- pnpm --filter @ingenuityai/backend run db:studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.10.5"
  }
}
